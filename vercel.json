{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*\\.geojson)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Content-Type",
          "value": "application/geo+json"
        }
      ]
    }
  ]
}
